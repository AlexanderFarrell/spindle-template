{
    "name": "walk-on-planets",
    "private": true,
    "version": "1.0.0",
    "type": "module",
	"main": "out/main/main.js",
    "scripts": {
		"dev": "vite --host",
		"build": "tsc && vite build",
		"dev:desktop": "electron-vite dev",
		"build:desktop": "electron-vite build && electron-builder",
		"build:desktop:win": "electron-vite build && electron-builder --win",
		"build:desktop:wine": "electron-vite build && electron-builder --win portable",
		"build:desktop:mac": "electron-vite build && electron-builder --mac",
		"build:desktop:linux": "electron-vite build && electron-builder --linux"
	},
	"dependencies": {
		"engine": "file:../spindle",
		"vite": "7.3.2",
		"electron-vite": "5.0.0"
	},
	"devDependencies": {
		"typescript": "^6.0.3",
		"electron": "42.0.0",
		"electron-builder": "26.8.1"
	},
	"build": {
		"appId": "com.alexanderfarrell.walkonplanetsremake",
		"productName": "3D RPG in TypeScript",
		"files": [
			"out/**",
			"package.json"
		],
		"directories": {
			"output": "release"
		},
		"linux": {
			"target": [
				"AppImage"
			]
		},
		"win": {
			"target": [
				"nsis"
			]
		},
		"mac": {
			"target": [
				"dmg"
			]
		}
	}
}